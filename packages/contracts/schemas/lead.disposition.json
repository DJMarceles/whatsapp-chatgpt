{
  "$id": "schemas/lead.disposition.json",
  "type": "object",
  "properties": {
    "lead_id": { "type": "string" },
    "outcome": { "type": "string", "enum": ["new_appointment", "call_back", "no_interest", "wrong_number"] },
    "note": { "type": "string" },
    "next_action_at": { "type": "string", "format": "date-time" },
