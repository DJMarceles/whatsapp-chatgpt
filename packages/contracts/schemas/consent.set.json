{
  "$id": "schemas/consent.set.json",
  "type": "object",
  "properties": {
    "subject_id": { "type": "string" },
    "channel": { "type": "string", "enum": ["email", "sms", "voice", "push"] },
    "status": { "type": "string", "enum": ["granted", "revoked", "unknown"] },
    "legal_basis": { "type": "string" },
    "effective_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "purpose": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    },
    "request_id": { "type": "string", "description": "idempotency key" }
  },
  "required": ["subject_id", "channel", "status", "effective_at", "request_id"],
  "additionalProperties": false
}
