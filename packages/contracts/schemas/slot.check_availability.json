{
  "$id": "schemas/slot.check_availability.json",
  "type": "object",
  "properties": {
    "start_from": { "type": "string", "format": "date-time" },
    "start_to": { "type": "string", "format": "date-time" },
    "duration_minutes": { "type": "integer", "minimum": 5 },
    "agent_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "service_type": { "type": "string" },
    "location": { "type": "string" },
    "request_id": { "type": "string", "description": "idempotency key" }
  },
  "required": ["start_from", "start_to", "duration_minutes", "request_id"],
  "additionalProperties": false
}
